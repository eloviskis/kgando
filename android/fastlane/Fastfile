default_platform(:android)

platform :android do

  # Lê senha do keystore do arquivo
  before_all do
    password_file = File.expand_path("../.keystore-password")
    if File.exist?(password_file)
      ENV["KEYSTORE_PASSWORD"] = File.read(password_file).strip
      ENV["KEY_PASSWORD"] = ENV["KEYSTORE_PASSWORD"]
    end
    ENV["ANDROID_HOME"] ||= File.expand_path("~/Library/Android/sdk")
    ENV["KEY_ALIAS"] ||= "kgando"
    ENV["KEYSTORE_PATH"] ||= File.expand_path("../kgando.keystore")
  end

  # Lane: build release AAB
  lane :build do
    gradle(
      project_dir: ".",
      task:         "bundle",
      build_type:   "Release",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
      }
    )
  end

  # Lane: publicar no track interno (internal testing)
  lane :deploy do
    build
    upload_to_play_store(
      track:            "internal",
      aab:              "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk:  true,
      release_status:   "draft",
      json_key:         ENV["PLAY_STORE_JSON_KEY"] || "fastlane/play_store_key.json",
    )
  end

  # Lane: promover de internal para alpha
  lane :promote_alpha do
    upload_to_play_store(
      track:              "internal",
      track_promote_to:   "alpha",
      skip_upload_aab:    true,
      skip_upload_apk:    true,
      json_key:           ENV["PLAY_STORE_JSON_KEY"] || "fastlane/play_store_key.json",
    )
  end

  # Lane: promover de alpha para produção
  lane :promote_production do
    upload_to_play_store(
      track:              "alpha",
      track_promote_to:   "production",
      rollout:            "0.1",
      skip_upload_aab:    true,
      skip_upload_apk:    true,
      json_key:           ENV["PLAY_STORE_JSON_KEY"] || "fastlane/play_store_key.json",
    )
  end

end
